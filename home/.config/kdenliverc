[KFileDialog Settings]
detailViewIconSize=0

[MainWindow]
Height 1440=960

ToolBarsMovable=Disabled
Width 2560=1707

[Recent Dirs]
KdenliveClipFolder[$e]=$HOME/Videos,$HOME/Documents

[Scope_Histogram]
autoRefresh=true
bEnabled=true
gEnabled=true
rEnabled=true
realtime=false
rec601=false
sEnabled=false
yEnabled=true

[Scope_RGB Parade]
autoRefresh=true
axis=false
gradref=false
paintmode=0
realtime=false

[Scope_Vectorscope]
75PBox=false
autoRefresh=true
axis=false
backgroundmode=0
colorspace_ypbpr=false
gain=1
iqlines=false
paintmode=0
realtime=false

[Scope_Waveform]
autoRefresh=true
paintmode=0
realtime=false
rec601=false

[UiSettings]
ColorScheme=Breeze Dark

[bin]


[capture]
decklink_extension=mov
decklink_parameters=vcodec=dnxhd vb=145000k acodec=pcm_s16le threads=%threads
grab_extension=mov
grab_parameters=-crf 25 -vcodec libx264 -preset veryfast -threads 0
v4l_extension=mpg
v4l_parameters=qscale=4 ab=192k vcodec=mpeg2video acodec=mp2 threads=%threads

[env]
defaultprojectfolder[$e]=$HOME/Videos
ffmpegpath[$e]=/usr/bin/ffmpeg
ffplaypath[$e]=/usr/bin/ffplay
ffprobepath[$e]=/usr/bin/ffprobe
mltpath[$e]=/usr/share/mlt/profiles
rendererpath[$e]=/usr/bin/melt

[project]
nvencEnabled=true

[timeline]
headerwidth=180
trackheight=68

[unmanaged]
default_profile=atsc_1080p_25
defaultrescaleheight=540
defaultrescalewidth=960
monitor_audio=false
producerslist=frei0r.ising0r,frei0r.lissajous0r,frei0r.nois0r,frei0r.onecol0r,frei0r.partik0l,frei0r.plasma,frei0r.test_pat_B,frei0r.test_pat_C,frei0r.test_pat_G,frei0r.test_pat_I,frei0r.test_pat_L,frei0r.test_pat_R,xml,xml-string,xml-nogl,vorbis,qimage,qtext,kdenlivetitle,ladspa.1047,ladspa.1050,blipflash,count,framebuffer,slowmotion,abnormal,color,colour,consumer,hold,loader,melt,melt_file,noise,timewarp,tone,decklink,avformat,avformat-novalidate,pango,pixbuf,pgm
widgetstyle=Default

